{
  "name": "mutatr-electron",
  "version": "0.1.0",
  "private": false,
  "description": "Mutatr desktop app prototype powered by Claude Agent SDK + Playwright",
  "license": "MIT",
  "author": "Novyn Labs",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite --strictPort --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && electron electron/main.mjs\"",
    "dev:renderer": "vite --strictPort --host 127.0.0.1 --port 5173",
    "build": "npm run build:renderer",
    "build:renderer": "vite build",
    "package": "npm run build:renderer && node ./scripts/run-electron-builder-mac.mjs --dir",
    "dist": "npm run build:renderer && node ./scripts/run-electron-builder-mac.mjs && node ./scripts/write-checksums.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node ./e2e/run-e2e.mjs",
    "test:e2e:live": "node ./e2e/run-live-e2e.mjs",
    "test:florinda:live": "node --test ./tests/florinda-programmatic.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/novynlabs/mutatr.git"
  },
  "homepage": "https://github.com/novynlabs/mutatr",
  "bugs": {
    "url": "https://github.com/novynlabs/mutatr/issues"
  },
  "keywords": [
    "electron",
    "ab-testing",
    "playwright",
    "claude",
    "experimentation"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "playwright": "^1.53.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.novynlabs.mutatr",
    "productName": "mutatr",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": true
    }
  }
}
