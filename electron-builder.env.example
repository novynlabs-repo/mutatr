# Copy to `electron-builder.env` for local notarized mac builds.
# electron-builder loads this file automatically from the project root.

# Apple notarization via App Store Connect API key
APPLE_API_KEY_ID=ABC1234567
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
APPLE_API_KEY=/absolute/path/to/AuthKey_ABC1234567.p8

# Optional but recommended when you notarize with a specific team
APPLE_TEAM_ID=TEAMID1234

# Optional signing certificate export for CI or machines without a configured keychain identity
# CSC_LINK=base64-or-file-url-to-your-developer-id-application-p12
# CSC_KEY_PASSWORD=your-p12-password
